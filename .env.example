# Frontend (Vite) — copy to .env.local
VITE_API_BASE=http://localhost:5000
VITE_GEMINI_API_KEY=

# Backend — copy to .env
JWT_SECRET=replace-with-a-long-random-secret
USE_MEMORY_DB=true
# Or set MONGO_URI to a real MongoDB connection string instead of USE_MEMORY_DB.
# MONGO_URI=
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Optional: seed admin user on startup
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me

# Optional: Gemini for API chatbot (rule-based fallback if unset)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
